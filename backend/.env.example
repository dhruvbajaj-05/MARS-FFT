# ---- FFT Manufacturing Backend — environment variables ----
# Copy this file to ".env" and fill in real values. Never commit the real .env.

# Server
PORT=5001
NODE_ENV=development

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/fft_manufacturing?retryWrites=true&w=majority
MONGODB_URI=YOUR_MONGODB_URI_HERE

# JWT settings
JWT_SECRET=FFT_MANUFACTURING_PLATFORM_SUPER_SECRET_2026
JWT_EXPIRY=7d

# Seed admin (used only by `npm run seed:admin`)
SEED_ADMIN_NAME=System Admin
SEED_ADMIN_EMAIL=admin@fft.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# Uploads (all optional — sensible defaults applied if omitted)
# UPLOAD_DIR=./public/uploads        # where image binaries are written
# PUBLIC_BASE_URL=http://localhost:5000   # absolute URL prefix for stored media
# MAX_IMAGE_BYTES=5242880            # max image size in bytes (default 5 MB)
# MAX_DOC_BYTES=10485760             # max document size in bytes (default 10 MB)
