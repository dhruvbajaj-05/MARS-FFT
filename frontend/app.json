{
  "expo": {
    "name": "FFT Manufacturing",
    "slug": "fft-manufacturing-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "fftmfg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fft.manufacturing",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to capture production, QC and dispatch photos.",
        "NSPhotoLibraryUsageDescription": "This app needs photo library access to attach images to records."
      }
    },
    "android": {
      "package": "com.funfactorytoys.marsfft",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow FFT Manufacturing to access your photos to attach record images.",
          "cameraPermission": "Allow FFT Manufacturing to use the camera to capture record photos."
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://mars-fft-production.up.railway.app",
      "eas": {
        "projectId": "ca2adca9-44a6-422c-ac62-008a717acf1d"
      }
    }
  }
}
